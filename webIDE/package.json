{
  "name": "webide-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n bridge,web -c cyan,magenta \"npm:dev:bridge\" \"npm:dev:web\"",
    "dev:web": "npm --workspace @webide/web run dev",
    "dev:bridge": "npm --workspace @webide/bridge run dev",
    "build": "npm run build:protocol && npm run build:knowledge && npm run build:bridge && npm run build:web",
    "build:protocol": "npm --workspace @webide/protocol run build",
    "build:knowledge": "npm --workspace @webide/knowledge-pack run build",
    "build:bridge": "npm --workspace @webide/bridge run build",
    "build:web": "npm --workspace @webide/web run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
